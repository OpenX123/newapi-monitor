# NewAPI 连接配置
NEWAPI_BASE_URL=https://your-newapi-domain.com
NEWAPI_ACCESS_TOKEN=your_access_token_here
NEWAPI_USER_ID=1

# PostgreSQL 数据库连接（直连 NewAPI 的数据库）
DATABASE_URL=postgres://user:password@localhost:5432/newapi

# 监控配置
DAILY_LIMIT=2000
POLL_INTERVAL=300000
PORT=3456

# SMTP 邮件通知（可选）
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your_email@qq.com
SMTP_PASS=your_smtp_password
